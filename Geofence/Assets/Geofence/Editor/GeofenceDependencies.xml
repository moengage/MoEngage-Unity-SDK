<?xml version="1.0" encoding="UTF-8" ?>
<dependencies>
  <androidPackages>
    <androidPackage spec="com.moengage:geofence:5.4.0"/>
    <androidPackage spec="com.moengage:unity-wrapper-geofence:2.0.0"/>
  </androidPackages>
  <!-- iOS Cocoapod dependencies can be specified by each iosPod element. -->
  <iosPods>
    <iosPod name="MoEngagePluginGeofence" version="4.9.0" minTargetSdk="13.0">
    </iosPod>
  </iosPods>

  <!-- SPM: replaces MoEngagePluginGeofence pod when SPM mode is active. -->
  <remoteSwiftPackage url="https://github.com/moengage/apple-plugin-geofence.git"
                      version="4.9.0">
    <swiftPackage name="MoEngagePluginGeofence" replacesPod="MoEngagePluginGeofence"/>
  </remoteSwiftPackage>
</dependencies>
